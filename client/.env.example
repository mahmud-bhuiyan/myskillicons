# Local — hit Express directly (CORS is enabled on the server):
VITE_API_URL=http://localhost:5000/api/v1

# Or use the Vite proxy instead:
# VITE_API_URL=/api/v1

# Production — after the server Vercel project is live, set this and redeploy the client:
# VITE_API_URL=https://your-api-project.vercel.app/api/v1
